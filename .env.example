# Neutral Detection Agents Workflow - Environment Variables Template

# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# DuckDuckGo Search (ddgs) Configuration
# ddgs does not require an API key, but uses a proxy to bypass rate limits
# Use http://rotating-proxy:5566 for Docker deployment
DDGS_PROXY=

# Application Configuration
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
ENV=dev         # dev, prod

# Database Paths (relative to project root)
MBFC_SQLITE_PATH=data/mbfc.sqlite
CHROMA_DB_PATH=data/chroma_db

# External Service Endpoints (if applicable)
CHROMA_SERVER_HOST=localhost
CHROMA_SERVER_PORT=8000
